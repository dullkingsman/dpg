{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DPG",
  "scopeName": "source.dpg",
  "fileTypes": ["dpg"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#dollar_strings" },
    { "include": "#strings" },
    { "include": "#dpg_block" },
    { "include": "#object_declarations" },
    { "include": "#block_directives" },
    { "include": "#macro_declaration" },
    { "include": "#macro_spread" },
    { "include": "#sql_keywords" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.dpg",
          "match": "--.*$"
        },
        {
          "name": "comment.block.dpg",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.dpg" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.dpg" } }
        }
      ]
    },
    "dollar_strings": {
      "name": "string.quoted.dollar.dpg",
      "begin": "\\$([a-zA-Z_][a-zA-Z0-9_]*)?\\$",
      "end": "\\$\\1\\$",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.dpg" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.dpg" }
      },
      "contentName": "meta.embedded.block.sql"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.dpg",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "match": "''", "name": "constant.character.escape.dpg" }
          ]
        },
        {
          "name": "string.quoted.double.dpg",
          "match": "\"[^\"]*\""
        }
      ]
    },
    "dpg_block": {
      "name": "meta.block.dpg",
      "begin": "(?<=\\)\\s*)\\{|^\\s*\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.block.begin.dpg" } },
      "endCaptures": { "0": { "name": "punctuation.section.block.end.dpg" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#block_directives" },
        { "include": "#strings" },
        { "include": "#nested_block" },
        { "include": "#macro_spread" },
        { "include": "#numbers" },
        { "include": "#identifiers" }
      ]
    },
    "nested_block": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.block.begin.dpg" } },
      "endCaptures": { "0": { "name": "punctuation.section.block.end.dpg" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#block_directives" },
        { "include": "#strings" },
        { "include": "#nested_block" },
        { "include": "#macro_spread" },
        { "include": "#numbers" },
        { "include": "#identifiers" }
      ]
    },
    "object_declarations": {
      "patterns": [
        {
          "name": "keyword.control.declaration.dpg",
          "match": "(?i)\\b(UNLOGGED\\s+TABLE|FOREIGN\\s+TABLE|MATERIALIZED\\s+VIEW|RECURSIVE\\s+VIEW|VIRTUAL\\s+TYPE|OPERATOR\\s+CLASS|OPERATOR\\s+FAMILY|EVENT\\s+TRIGGER|DEFAULT\\s+PRIVILEGES|FOREIGN\\s+DATA\\s+WRAPPER|USER\\s+MAPPING|TEXT\\s+SEARCH\\s+CONFIGURATION|TEXT\\s+SEARCH\\s+DICTIONARY|TEXT\\s+SEARCH\\s+PARSER|TEXT\\s+SEARCH\\s+TEMPLATE|TABLE|VIEW|FUNCTION|PROCEDURE|AGGREGATE|ENUM|TYPE|DOMAIN|SCHEMA|EXTENSION|SEQUENCE|ROLE|TABLESPACE|PUBLICATION|SUBSCRIPTION|COLLATION|OPERATOR|CAST|STATISTICS|SERVER)\\b"
        },
        {
          "name": "keyword.control.macro.dpg",
          "match": "(?i)\\bMACRO\\b"
        }
      ]
    },
    "block_directives": {
      "patterns": [
        {
          "name": "keyword.other.lifecycle.dpg",
          "match": "(?i)\\b(RENAMED\\s+FROM|DROP\\s+CASCADE|MIGRATE\\s+REMOVE|PROTECTED|DEPRECATED)\\b"
        },
        {
          "name": "keyword.other.directive.dpg",
          "match": "(?i)\\b(PREFERRED\\s+JSON\\s+FORMAT|COMMENT|OWNER|INDICES|INDEX|POLICIES|POLICY|TRIGGERS|TRIGGER|COLUMNS|COLUMN|CONSTRAINTS|CONSTRAINT|GRANTS|GRANT|REVOCATIONS|REVOCATION|PARTITIONS|PARTITION|MAPPING)\\b"
        },
        {
          "name": "keyword.other.privilege.dpg",
          "match": "(?i)\\b(SELECT|INSERT|UPDATE|DELETE|TRUNCATE|REFERENCES|TRIGGER|USAGE|EXECUTE|CREATE|CONNECT|TEMPORARY|ALL\\s+PRIVILEGES)\\b"
        }
      ]
    },
    "macro_declaration": {
      "match": "(?i)\\bMACRO\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "entity.name.macro.dpg" }
      }
    },
    "macro_spread": {
      "name": "meta.spread.dpg",
      "match": "\\.\\.\\.([a-zA-Z_][a-zA-Z0-9_$]*)",
      "captures": {
        "0": { "name": "keyword.operator.spread.dpg" },
        "1": { "name": "variable.other.readwrite.dpg" }
      }
    },
    "sql_keywords": {
      "name": "keyword.other.sql.dpg",
      "match": "(?i)\\b(AS|FROM|WHERE|JOIN|ON|AND|OR|NOT|NULL|TRUE|FALSE|RETURNS|LANGUAGE|IMMUTABLE|STABLE|VOLATILE|STRICT|SECURITY|DEFINER|INVOKER|PARALLEL|UNSAFE|SAFE|RESTRICTED|FOR|IN|TO|WITH|BY|NO|DEFAULT|PRIMARY|KEY|UNIQUE|FOREIGN|REFERENCES|CHECK|GENERATED|ALWAYS|IDENTITY|IS|LIKE|BETWEEN|EXISTS|CASE|WHEN|THEN|ELSE|END|DISTINCT|GROUP|ORDER|HAVING|LIMIT|OFFSET|UNION|INTERSECT|EXCEPT|NULLS|FIRST|LAST|ASC|DESC|CASCADE|RESTRICT|DEFERRABLE|INITIALLY|DEFERRED|IMMEDIATE|SUPERUSER|NOSUPERUSER|CREATEDB|NOCREATEDB|CREATEROLE|NOCREATEROLE|INHERIT|NOINHERIT|LOGIN|NOLOGIN|REPLICATION|NOREPLICATION|BYPASSRLS|NOBYPASSRLS|PASSWORD|VALID|UNTIL|CACHE|CYCLE|MAXVALUE|MINVALUE|INCREMENT|START|OWNED|STORAGE|COMPRESSION|INCLUDE|EXCLUDE|SPATIAL|FULLTEXT|VARIADIC|INOUT|OUT|HANDLER|VALIDATOR|AFTER|BEFORE|EACH|INSTEAD|STATEMENT|ROW|ADMIN|OF|DATABASE|LOCATION|VERSION|PUBLIC|OPTION|OPTIONS|CONNECTION|IMPLICIT|ASSIGNMENT|TIME|ZONE|TAG|VALUES|WITHOUT|INHERITS|OIDS|STORED|MATCH|FULL|PARTIAL|SIMPLE|ACTION|RULE|HASH|LIST|RANGE|JSON|JSONB)\\b"
    },
    "numbers": {
      "name": "constant.numeric.dpg",
      "match": "-?\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "booleans": {
      "name": "constant.language.dpg",
      "match": "(?i)\\b(TRUE|FALSE|NULL)\\b"
    },
    "identifiers": {
      "name": "variable.other.dpg",
      "match": "[a-zA-Z_][a-zA-Z0-9_$]*"
    }
  }
}
